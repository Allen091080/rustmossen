{
  "name": "mossen-code-src",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "bin": {
    "mossen": "./run-mossen.sh"
  },
  "scripts": {
    "start": "./run-mossen.sh",
    "help": "./run-mossen.sh --help",
    "start:source": "./run-mossen.sh",
    "start:apple-debug": "MOSSENSRC_DEBUG_INPUT=1 ./run-mossen.sh --debug --debug-file ./.mossensrc/apple-terminal-input.log",
    "link:global": "npm link",
    "platform:check": "./run-bun-featured.sh scripts/platform_check.ts",
    "feature:audit": "python3 scripts/feature_audit.py",
    "typecheck": "tsc --noEmit",
    "typecheck:diff": "python3 scripts/typecheck_diff.py",
    "lint": "eslint .",
    "lint:diff": "python3 scripts/lint_diff.py",
    "harness": "python3 scripts/smoke_check.py",
    "harness:gate": "bun run typecheck:diff && bun run lint:diff && bun run harness"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.18.0",
    "asciichart": "^1.5.25",
    "audio-capture-napi": "^0.0.1",
    "auto-bind": "^5.0.1",
    "axios": "^1.15.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "color-diff-napi": "^0.0.1",
    "commander": "~14.0.0",
    "diff": "^9.0.0",
    "emoji-regex": "^10.6.0",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "fuse.js": "^7.3.0",
    "get-east-asian-width": "^1.5.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^9.0.0",
    "ignore": "^7.0.5",
    "indent-string": "^5.0.0",
    "ink": "^7.0.1",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.3.5",
    "marked": "^18.0.1",
    "modifiers-napi": "^0.0.1",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "shell-quote": "^1.8.3",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^5.6.0",
    "undici": "^8.1.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.20.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
