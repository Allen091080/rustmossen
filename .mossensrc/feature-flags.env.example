# .mossensrc/feature-flags.env.example — Bun feature flag 推荐配置模板
#
# 用法:
#   1) 复制本文件为 .mossensrc/feature-flags.env (本仓 .gitignore 忽略真实 .env)
#   2) 按需启用以下 token, 多个用逗号分隔, 不留空格
#   3) `./run-mossen.sh` / `run-bun-featured.sh` 启动时自动读取
#
# 红线:
#   - 不要 commit 你的真实 .mossensrc/feature-flags.env (per-developer, 各人不同)
#   - 已废弃 token (例: BRIDGE_MODE, Wave 5 Phase 2 已清) 不再被任何 feature() / resolve() 引用,
#     即使写入也不生效
#   - token 命名必须出现在 `scripts/feature-flag-token-whitelist.txt` (R8.2 smoke 强制校验)
#
# 维护责任: 同 commit 改 `scripts/feature-flag-token-whitelist.txt` (新增/移除 token 时)

# ============================================================
# 推荐配置 (Mossen 个人版常用)
# ============================================================
# 取消下行注释即可启用 (覆盖你的 shell 已有 MOSSENSRC_BUN_FEATURES)
#export MOSSENSRC_BUN_FEATURES="DIRECT_CONNECT,SSH_REMOTE,TRANSCRIPT_CLASSIFIER,KAIROS,VOICE_MODE,TEAMMEM"

# 安全用法 (仅在 shell 未设置时填默认):
#export MOSSENSRC_BUN_FEATURES="${MOSSENSRC_BUN_FEATURES:-DIRECT_CONNECT,SSH_REMOTE,TRANSCRIPT_CLASSIFIER,KAIROS,VOICE_MODE,TEAMMEM}"

# ============================================================
# 运行时配置覆盖 (MOSSEN_CONFIG_OVERRIDES)
# ============================================================
# 运行时 feature gate 通过环境变量 MOSSEN_CONFIG_OVERRIDES (JSON) 控制。
# 注意区分两个层级:
#
# auto memory: 默认启用 (isAutoMemoryEnabled())，无需额外 gate。
#   - 控制 extractMemories 是否写入 private memory 目录。
#   - 关闭: 设置 MOSSEN_CODE_DISABLE_AUTO_MEMORY=1 或 settings.autoMemoryEnabled=false
#
# team memory: 默认关闭，需要显式启用。
#   - 控制 extractMemories 是否写入 team memory 目录 (memory/team/)。
#   - TEAMMEM build flag 仅表示编译包含 team memory 代码路径，不代表 runtime 启用。
#   - 启用: 在 MOSSEN_CONFIG_OVERRIDES 中设置 mossen.memory.teamMemoryEnabled=true
#   - 与 KAIROS daily-log gate (mossen.memory.kairosActive) 是独立的两个 gate。
#
# 示例 — 启用 team memory (仅当你明确需要团队共享记忆时):
#export MOSSEN_CONFIG_OVERRIDES='{"mossen.memory.teamMemoryEnabled":true}'
#
# 示例 — 同时启用 KAIROS daily-log 和 team memory:
#export MOSSEN_CONFIG_OVERRIDES='{"mossen.memory.kairosActive":true,"mossen.memory.teamMemoryEnabled":true}'

# ============================================================
# 全部可用 token 速查 (按主题分组, 79 项, 与 whitelist 一致)
# ============================================================

# --- 网络 / 后端连通 ---
# DIRECT_CONNECT             直连后端 (推荐)
# SSH_REMOTE                 SSH 远程会话
# DAEMON                     mossen daemon 守护态
# UDS_INBOX                  Unix domain socket inbox
# CCR_REMOTE_SETUP           CCR 远程配置

# --- 模型 / 推理 ---
# TRANSCRIPT_CLASSIFIER      转录分类 (推荐)
# BASH_CLASSIFIER            bash 命令分类
# AUTO_THEME                 自动主题识别
# CACHED_MICROCOMPACT        微压缩缓存
# REACTIVE_COMPACT           响应式压缩
# COMPACTION_REMINDERS       压缩提醒
# CONTEXT_COLLAPSE           上下文折叠
# PROMPT_CACHE_BREAK_DETECTION  prompt cache 断点检测
# BREAK_CACHE_COMMAND        手动断 cache 命令
# TOKEN_BUDGET               token 预算守卫
# ANTI_DISTILLATION_CC       反蒸馏 CC

# --- Kairos 主线 ---
# KAIROS                     Kairos 总开关 (推荐)
# KAIROS_BRIEF               Kairos 简报
# KAIROS_CHANNELS            Kairos 频道
# KAIROS_DREAM               Kairos dream
# KAIROS_GITHUB_WEBHOOKS     Kairos GitHub webhooks
# KAIROS_PUSH_NOTIFICATION   Kairos 推送通知

# --- Agent / 工作流 ---
# AGENT_MEMORY_SNAPSHOT      agent 记忆快照
# AGENT_TRIGGERS             agent 触发器
# AGENT_TRIGGERS_REMOTE      agent 远程触发器
# BUILTIN_EXPLORE_PLAN_AGENTS  内建 explore/plan 子 agent
# COORDINATOR_MODE           协调者模式
# FORK_SUBAGENT              子 agent fork
# PROACTIVE                  主动 agent 行为
# VERIFICATION_AGENT         验证 agent
# WORKFLOW_SCRIPTS           工作流脚本
# RUN_SKILL_GENERATOR        skill 生成器
# SKILL_IMPROVEMENT          skill 改进

# --- UI / TUI / 输出 ---
# VOICE_MODE                 语音模式 (推荐)
# STREAMLINED_OUTPUT         精简输出
# MESSAGE_ACTIONS            消息操作菜单
# HISTORY_PICKER             历史选取
# HISTORY_SNIP               历史片段
# QUICK_SEARCH               快速搜索
# CONNECTOR_TEXT             连接器文案
# TERMINAL_PANEL             终端面板 (实验)
# NATIVE_CLIPBOARD_IMAGE     系统粘贴板图片
# NATIVE_CLIENT_ATTESTATION  本地客户端 attestation
# REVIEW_ARTIFACT            review artifact
# MCP_RICH_OUTPUT            MCP 富输出
# MCP_SKILLS                 MCP skills

# --- 团队 / 协作 ---
# TEAMMEM                    团队记忆编译包含 (build flag; runtime 需额外启用 mossen.memory.teamMemoryEnabled)
# COMMIT_ATTRIBUTION         commit 归属
# BUDDY                      buddy 协作
# COWORKER_TYPE_TELEMETRY    coworker 类型遥测
# MEMORY_SHAPE_TELEMETRY     记忆形态遥测

# --- 编辑 / 文件 ---
# FILE_PERSISTENCE           文件持久化
# TEMPLATES                  模板
# TREE_SITTER_BASH           tree-sitter bash
# TREE_SITTER_BASH_SHADOW    tree-sitter bash shadow
# WEB_BROWSER_TOOL           web browser 工具
# MONITOR_TOOL               monitor 工具
# OVERFLOW_TEST_TOOL         overflow 测试工具
# CHICAGO_MCP                Chicago MCP

# --- 后台 / 持久 ---
# BG_SESSIONS                后台会话
# AWAY_SUMMARY               离线摘要
# UNATTENDED_RETRY           无人值守重试
# HOOK_PROMPTS               hook 提示
# SLOW_OPERATION_LOGGING     慢操作日志
# SHOT_STATS                 shot 统计

# --- 调试 / 实验 ---
# ULTRATHINK                 ultrathink
# ULTRAPLAN                  ultraplan
# TORCH                      torch (实验)
# LODESTONE                  lodestone (实验)
# NEW_INIT                   新 init 流程
# BUILDING_MOSSEN_APPS       Mossen apps 构建
# DOWNLOAD_USER_SETTINGS     下载用户设置
# UPLOAD_USER_SETTINGS       上传用户设置
# POWERSHELL_AUTO_MODE       PowerShell 自动模式
# HARD_FAIL                  hard fail (调试用)
# ALLOW_TEST_VERSIONS        允许测试版
# SKIP_DETECTION_WHEN_AUTOUPDATES_DISABLED  自动更新禁用时跳过检测
# IS_LIBC_GLIBC              libc=glibc 标记
# IS_LIBC_MUSL               libc=musl 标记

# ============================================================
# 已废弃 (历史遗留, 不再被引用 — 写入无效)
# ============================================================
# BRIDGE_MODE                Wave 1.5 Bridge 子系统已删, Wave 5 Phase 2 清空 resolve/type 残留
